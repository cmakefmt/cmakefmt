// Responsive feature highlights with inline SVG icons.
---

<div class="feature-showcase not-content">
  <div class="feature-item">
    <span class="feature-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="12" rx="2"></rect>
        <path d="M8 20h8"></path>
        <path d="M10 8h4"></path>
        <path d="M9 11h6"></path>
      </svg>
    </span>
    <span class="feature-title">LSP Server</span>
    <span class="feature-desc">Format-on-save in any editor via <code>cmakefmt lsp</code></span>
  </div>
  <div class="feature-item">
    <span class="feature-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 21s7-3.5 7-9V5l-7-3-7 3v7c0 5.5 7 9 7 9Z"></path>
        <path d="m9.5 11.5 1.8 1.8 3.7-3.7"></path>
      </svg>
    </span>
    <span class="feature-title">Pre-commit</span>
    <span class="feature-desc">One-line hook for CI and local workflows</span>
  </div>
  <div class="feature-item">
    <span class="feature-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 3l4 4-4 4"></path>
        <path d="M3 7h18"></path>
        <path d="m7 21-4-4 4-4"></path>
        <path d="M21 17H3"></path>
      </svg>
    </span>
    <span class="feature-title">Legacy Migration</span>
    <span class="feature-desc">Convert cmake-format configs in one command</span>
  </div>
  <div class="feature-item">
    <span class="feature-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="m12 3 1.25 3.75L17 8l-3.75 1.25L12 13l-1.25-3.75L7 8l3.75-1.25L12 3Z"></path>
        <path d="m18.5 13 0.8 2.2 2.2 0.8-2.2 0.8-0.8 2.2-0.8-2.2-2.2-0.8 2.2-0.8 0.8-2.2Z"></path>
        <path d="m5.5 13.5 0.65 1.85L8 16l-1.85 0.65L5.5 18.5l-0.65-1.85L3 16l1.85-0.65 0.65-1.85Z"></path>
      </svg>
    </span>
    <span class="feature-title">Config Autocomplete</span>
    <span class="feature-desc">JSON Schema registered with SchemaStore</span>
  </div>
</div>

<style>
  .feature-showcase {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 2rem 0;
  }

  @media (min-width: 42rem) {
    .feature-showcase {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 70rem) {
    .feature-showcase {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0.375rem;
    height: 100%;
    margin: 0;
    padding: 1.25rem;
    border-radius: 0.75rem;
    min-height: 0;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 25%, transparent);
    background: color-mix(in srgb, var(--sl-color-gray-6) 50%, transparent);
    backdrop-filter: blur(8px);
    transition:
      border-color 0.3s ease,
      transform 0.3s ease;
  }

  .feature-item:hover {
    border-color: color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
    transform: translateY(-2px);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    color: var(--sl-color-text-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 18%, transparent);
  }

  .feature-icon svg {
    width: 1.2rem;
    height: 1.2rem;
    flex: 0 0 auto;
  }

  .feature-title {
    font-family: var(--sl-font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .feature-desc {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }

  .feature-desc :global(code) {
    font-size: inherit;
    background: none;
    color: var(--sl-color-text-accent);
    padding: 0;
    border-radius: 0;
    box-shadow: none;
    white-space: normal;
    overflow-wrap: anywhere;
  }
</style>

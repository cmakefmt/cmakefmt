<div class="chart-wrapper">
  <canvas id="speedup-chart" aria-label="Per-fixture speedup of cmakefmt over cmake-format"></canvas>
</div>

<script>
import { Chart, BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend } from 'chart.js';
Chart.register(BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend);

const DATA = [
  { label: 'abseil',         lines: 280,  speedup: 32.27 },
  { label: 'catch2',         lines: 230,  speedup: 21.34 },
  { label: 'cli11',          lines: 283,  speedup: 24.35 },
  { label: 'cmake_cmbzip2',  lines: 25,   speedup: 13.81 },
  { label: 'googletest',     lines: 36,   speedup: 14.91 },
  { label: 'ggml',           lines: 498,  speedup: 29.33 },
  { label: 'llama_cpp',      lines: 286,  speedup: 22.80 },
  { label: 'llvm_tablegen',  lines: 83,   speedup: 17.93 },
  { label: 'mariadb_server', lines: 656,  speedup: 53.76 },
  { label: 'nlohmann_json',  lines: 237,  speedup: 27.92 },
  { label: 'opencv_flann',   lines: 2,    speedup: 12.86 },
  { label: 'protobuf',       lines: 351,  speedup: 20.94 },
  { label: 'spdlog',         lines: 413,  speedup: 34.17 },
  { label: 'qtbase_network', lines: 420,  speedup: 37.41 },
  { label: 'xnnpack',        lines: 1354, speedup: 53.14 },
];

const GEO_MEAN = 25.33;

function isDark() {
  return document.documentElement.dataset.theme === 'dark';
}

function colors() {
  const dark = isDark();
  return {
    bar:      dark ? 'hsl(198,93%,60%)' : 'hsl(200,98%,39%)',
    barHover: dark ? 'hsl(198,93%,70%)' : 'hsl(200,98%,28%)',
    refLine:  dark ? 'hsl(240,5%,55%)'  : 'hsl(240,4%,55%)',
    grid:     dark ? 'hsl(240,4%,20%)'  : 'hsl(240,6%,90%)',
    text:     dark ? 'hsl(0,0%,100%)'   : 'hsl(240,6%,10%)',
    subtext:  dark ? 'hsl(240,5%,65%)'  : 'hsl(240,4%,46%)',
  };
}

const canvas = document.getElementById('speedup-chart') as HTMLCanvasElement;
let chart: Chart | null = null;

function buildChart() {
  const c = colors();
  if (chart) chart.destroy();

  chart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: DATA.map(d => d.label),
      datasets: [
        {
          label: 'Speedup vs cmake-format',
          data: DATA.map(d => d.speedup),
          backgroundColor: c.bar,
          hoverBackgroundColor: c.barHover,
          borderRadius: 3,
          borderSkipped: false,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      scales: {
        x: {
          ticks: {
            color: c.subtext,
            font: { size: 11 },
            maxRotation: 35,
            minRotation: 35,
          },
          grid: { color: c.grid },
          border: { color: c.grid },
        },
        y: {
          title: {
            display: true,
            text: 'Speedup (×)',
            color: c.subtext,
            font: { size: 11 },
          },
          min: 0,
          ticks: {
            color: c.subtext,
            font: { size: 11 },
            callback: (v) => `${v}×`,
          },
          grid: { color: c.grid },
          border: { color: c.grid },
        },
      },
      plugins: {
        legend: { display: false },
        annotation: undefined,
        tooltip: {
          backgroundColor: isDark() ? 'hsl(240,6%,14%)' : 'hsl(0,0%,100%)',
          borderColor: isDark() ? 'hsl(240,4%,24%)' : 'hsl(240,6%,90%)',
          borderWidth: 1,
          titleColor: c.text,
          bodyColor: c.subtext,
          padding: 10,
          callbacks: {
            title: (items) => {
              const d = DATA[items[0].dataIndex];
              return `${d.label}  (${d.lines} lines)`;
            },
            label: (item) => {
              const d = DATA[item.dataIndex];
              return `  ${d.speedup}× faster than cmake-format`;
            },
            afterBody: () => `  Geo-mean across all fixtures: ${GEO_MEAN}×`,
          },
        },
      },
    },
    plugins: [
      {
        id: 'geo-mean-line',
        afterDraw(chart) {
          const { ctx, scales: { y } } = chart;
          const yPos = y.getPixelForValue(GEO_MEAN);
          const left = chart.chartArea.left;
          const right = chart.chartArea.right;
          ctx.save();
          ctx.setLineDash([5, 4]);
          ctx.strokeStyle = c.refLine;
          ctx.lineWidth = 1.5;
          ctx.beginPath();
          ctx.moveTo(left, yPos);
          ctx.lineTo(right, yPos);
          ctx.stroke();
          ctx.setLineDash([]);
          ctx.font = '11px system-ui, sans-serif';
          ctx.fillStyle = c.refLine;
          ctx.textAlign = 'right';
          ctx.fillText(`geo-mean ${GEO_MEAN}×`, right - 4, yPos - 5);
          ctx.restore();
        },
      },
    ],
  });
}

buildChart();

const observer = new MutationObserver(() => buildChart());
observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>

<style>
  .chart-wrapper {
    position: relative;
    width: 100%;
    max-width: 860px;
    margin: 1.5rem auto;
    border: 1px solid var(--sl-color-hairline, hsl(240, 6%, 90%));
    border-radius: 0.75rem;
    padding: 1.5rem 1rem 1rem;
    background: color-mix(in srgb, var(--sl-color-accent-low, hsl(200, 98%, 95%)) 10%, transparent);
  }
</style>

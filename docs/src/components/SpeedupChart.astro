<div class="chart-wrapper" data-speedup-chart>
  <canvas id="speedup-chart" aria-label="Per-fixture speedup of cmakefmt over cmake-format"></canvas>
</div>

<script>
import { Chart, BarController, BarElement, CategoryScale, LinearScale, LogarithmicScale, Tooltip, Legend } from 'chart.js';
Chart.register(BarController, BarElement, CategoryScale, LinearScale, LogarithmicScale, Tooltip, Legend);

const DATA = [
  { label: 'opencv_flann',   lines: 2,     speedup: 6.8 },
  { label: 'googletest',     lines: 36,    speedup: 13.1 },
  { label: 'llvm_tablegen',  lines: 83,    speedup: 8.7 },
  { label: 'abseil',         lines: 280,   speedup: 16.5 },
  { label: 'spdlog',         lines: 413,   speedup: 19.9 },
  { label: 'mariadb_server', lines: 656,   speedup: 41.1 },
  { label: 'xnnpack',        lines: 1354,  speedup: 81.4 },
  { label: 'opencv_root',    lines: 2039,  speedup: 1477.2 },
  { label: 'blender_root',   lines: 2650,  speedup: 53.6 },
  { label: 'llvm_libc_math', lines: 6688,  speedup: 109.1 },
  { label: 'grpc_root',      lines: 54834, speedup: 424.4 },
];

const GEO_MEAN = 48.0;

function isDark() {
  return document.documentElement.dataset.theme === 'dark';
}

function colors() {
  const dark = isDark();
  return {
    bar:      dark ? 'hsl(198,93%,60%)' : 'hsl(200,98%,39%)',
    barHover: dark ? 'hsl(198,93%,70%)' : 'hsl(200,98%,28%)',
    refLine:  dark ? 'hsl(240,5%,55%)'  : 'hsl(240,4%,55%)',
    grid:     dark ? 'hsl(240,4%,20%)'  : 'hsl(240,6%,90%)',
    text:     dark ? 'hsl(0,0%,100%)'   : 'hsl(240,6%,10%)',
    subtext:  dark ? 'hsl(240,5%,65%)'  : 'hsl(240,4%,46%)',
  };
}

function buildChart(canvas: HTMLCanvasElement) {
  const c = colors();
  Chart.getChart(canvas)?.destroy();

  new Chart(canvas, {
    type: 'bar',
    data: {
      labels: DATA.map(d => d.label),
      datasets: [
        {
          label: 'Speedup vs cmake-format',
          data: DATA.map(d => d.speedup),
          backgroundColor: c.bar,
          hoverBackgroundColor: c.barHover,
          borderRadius: 3,
          borderSkipped: false,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      scales: {
        x: {
          ticks: {
            color: c.subtext,
            font: { size: 11 },
            maxRotation: 35,
            minRotation: 35,
          },
          grid: { color: c.grid },
          border: { color: c.grid },
        },
        y: {
          type: 'logarithmic',
          title: {
            display: true,
            text: 'Speedup (×, log scale)',
            color: c.subtext,
            font: { size: 11 },
          },
          min: 1,
          ticks: {
            color: c.subtext,
            font: { size: 11 },
            callback: (v) => {
              const log = Math.log10(Number(v));
              return Math.abs(log - Math.round(log)) < 1e-9 ? `${v}×` : null;
            },
          },
          grid: { color: c.grid },
          border: { color: c.grid },
        },
      },
      plugins: {
        legend: { display: false },
        annotation: undefined,
        tooltip: {
          backgroundColor: isDark() ? 'hsl(240,6%,14%)' : 'hsl(0,0%,100%)',
          borderColor: isDark() ? 'hsl(240,4%,24%)' : 'hsl(240,6%,90%)',
          borderWidth: 1,
          titleColor: c.text,
          bodyColor: c.subtext,
          padding: 10,
          callbacks: {
            title: (items) => {
              const d = DATA[items[0].dataIndex];
              return `${d.label}  (${d.lines} lines)`;
            },
            label: (item) => {
              const d = DATA[item.dataIndex];
              return `  ${d.speedup}× faster than cmake-format`;
            },
            afterBody: () => `  Geo-mean across all fixtures: ${GEO_MEAN}×`,
          },
        },
      },
    },
    plugins: [
      {
        id: 'geo-mean-line',
        afterDraw(chart) {
          const { ctx, scales: { y } } = chart;
          const yPos = y.getPixelForValue(GEO_MEAN);
          const left = chart.chartArea.left;
          const right = chart.chartArea.right;
          ctx.save();
          ctx.setLineDash([5, 4]);
          ctx.strokeStyle = c.refLine;
          ctx.lineWidth = 1.5;
          ctx.beginPath();
          ctx.moveTo(left, yPos);
          ctx.lineTo(right, yPos);
          ctx.stroke();
          ctx.setLineDash([]);
          ctx.font = '11px system-ui, sans-serif';
          ctx.fillStyle = c.refLine;
          ctx.textAlign = 'right';
          ctx.fillText(`geo-mean ${GEO_MEAN}×`, right - 4, yPos - 5);
          ctx.restore();
        },
      },
    ],
  });
}

function initSpeedupCharts() {
  document.querySelectorAll('[data-speedup-chart]').forEach((wrapper) => {
    if (!(wrapper instanceof HTMLDivElement)) {
      return;
    }

    const canvas = wrapper.querySelector('#speedup-chart');
    if (!(canvas instanceof HTMLCanvasElement)) {
      return;
    }

    buildChart(canvas);
  });
}

const speedupChartWindow = window as Window & {
  __speedupChartsRegistered?: boolean;
};

if (!speedupChartWindow.__speedupChartsRegistered) {
  speedupChartWindow.__speedupChartsRegistered = true;
  document.addEventListener('astro:page-load', initSpeedupCharts);

  const observer = new MutationObserver(() => initSpeedupCharts());
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });
}

initSpeedupCharts();
</script>

<style>
  .chart-wrapper {
    position: relative;
    width: 100%;
    max-width: 860px;
    margin: 1.5rem auto;
    border: 1px solid var(--sl-color-hairline, hsl(240, 6%, 90%));
    border-radius: 0.75rem;
    padding: 1.5rem 1rem 1rem;
    background: color-mix(in srgb, var(--sl-color-accent-low, hsl(200, 98%, 95%)) 10%, transparent);
  }
</style>

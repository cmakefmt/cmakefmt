// Install command with one-click copy button.
interface Props {
  cmd: string;
  label?: string;
}

const { cmd, label } = Astro.props;
---

<div class="install-cmd not-content">
  {label && <span class="install-cmd-label">{label}</span>}
  <div class="install-cmd-box">
    <code class="install-cmd-text"><span class="install-cmd-prompt">❯ </span>{cmd}</code>
    <button class="install-cmd-copy" aria-label="Copy to clipboard" data-cmd={cmd}>
      <svg class="install-cmd-icon install-cmd-icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <svg class="install-cmd-icon install-cmd-icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </button>
  </div>
</div>

<style>
  .install-cmd {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    margin: 0.75rem 0;
    width: 100%;
  }

  .install-cmd-label {
    font-family: var(--sl-font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--sl-color-text-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .install-cmd-box {
    display: inline-grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 30%, transparent);
    background: color-mix(in srgb, var(--sl-color-gray-6) 70%, transparent);
    backdrop-filter: blur(8px);
    font-family: var(--sl-font-mono);
    font-size: 0.8125rem;
    width: fit-content;
    max-width: min(100%, 42rem);
    margin-inline: auto;
    overflow: hidden;
  }

  .install-cmd-prompt {
    color: var(--sl-color-gray-3);
    user-select: none;
  }

  .install-cmd-text {
    min-width: 0;
    display: block;
    color: var(--sl-color-white);
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    box-shadow: none;
    overflow-x: auto;
    overflow-y: hidden;
    white-space: nowrap;
    scrollbar-width: thin;
  }

  .install-cmd-copy {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border: none;
    border-radius: 0.375rem;
    background: transparent;
    color: var(--sl-color-gray-3);
    line-height: 0;
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .install-cmd-copy:hover {
    color: var(--sl-color-text-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }

  .install-cmd-icon {
    grid-area: 1 / 1;
    width: 16px;
    height: 16px;
    display: block;
    pointer-events: none;
    transition:
      opacity 0.16s ease,
      transform 0.16s ease;
  }

  .install-cmd-icon-copy {
    opacity: 1;
    transform: none;
  }

  .install-cmd-icon-check {
    color: hsl(142, 71%, 45%);
    opacity: 0;
    transform: scale(0.9);
  }

  .install-cmd-copy.is-copied .install-cmd-icon-copy {
    opacity: 0;
    transform: scale(0.9);
  }

  .install-cmd-copy.is-copied .install-cmd-icon-check {
    opacity: 1;
    transform: none;
  }

  @media (max-width: 40rem) {
    .install-cmd-box {
      padding: 0.5rem 0.75rem;
      gap: 0.5rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.install-cmd-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const cmd = (btn as HTMLElement).dataset.cmd || '';
      await navigator.clipboard.writeText(cmd);
      btn.classList.add('is-copied');

      setTimeout(() => {
        btn.classList.remove('is-copied');
      }, 2000);
    });
  });
</script>

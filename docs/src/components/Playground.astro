// Interactive cmakefmt playground — formats CMake code in the browser via WASM.
---

<div class="playground" id="playground">
  <div class="playground-toolbar">
    <div class="playground-toolbar-left">
      <button id="btn-format" class="playground-btn playground-btn-primary" disabled>
        Format
      </button>
      <button id="btn-reset" class="playground-btn">Reset</button>
      <button id="btn-copy" class="playground-btn">Copy</button>
      <button id="btn-share" class="playground-btn">Share</button>
    </div>
    <div class="playground-toolbar-presets">
      <label class="playground-select-label" for="source-preset">Source</label>
      <select id="source-preset" class="playground-select">
        <option value="minimal">Minimal project</option>
        <option value="install">install(TARGETS)</option>
        <option value="comments">Comments + barriers</option>
        <option value="wrapping">Wrap behavior</option>
      </select>
      <label class="playground-select-label" for="config-preset">Config</label>
      <select id="config-preset" class="playground-select">
        <option value="default">Default</option>
        <option value="custom-command">Custom command</option>
        <option value="cmake-format">cmake-format style</option>
        <option value="wide">Wide lines</option>
      </select>
    </div>
    <span id="playground-status" class="playground-status">Loading WASM&hellip;</span>
  </div>

  <div id="playground-tip" class="playground-tip" role="alert">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" style="flex-shrink:0">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
    </svg>
    <span>
      Pick a source or config preset, then format. The Share button stores the current source and
      config in the URL.
    </span>
  </div>

  <div class="playground-body">
    <div class="playground-pane">
      <div class="playground-pane-tabs">
        <button class="playground-tab active" data-tab="source">Source</button>
        <button class="playground-tab" data-tab="config">Config</button>
      </div>
      <div id="editor-source" class="playground-editor" data-tab-panel="source"></div>
      <div id="editor-config" class="playground-editor" data-tab-panel="config" hidden></div>
    </div>

    <div class="playground-pane">
      <div class="playground-pane-header">Formatted Output</div>
      <div id="editor-output" class="playground-editor"></div>
    </div>
  </div>
</div>

<script>
  import { EditorView, keymap, lineNumbers, highlightActiveLine, highlightActiveLineGutter } from '@codemirror/view';
  import { Compartment, EditorState } from '@codemirror/state';
  import { defaultKeymap, history, historyKeymap, indentWithTab } from '@codemirror/commands';
  import { syntaxHighlighting, bracketMatching, StreamLanguage } from '@codemirror/language';
  import { yaml } from '@codemirror/lang-yaml';
  import { HighlightStyle } from '@codemirror/language';
  import { tags } from '@lezer/highlight';

  // ── CMake syntax highlighting ──────────────────────────────────────

  const cmakeLanguage = StreamLanguage.define({
    token(stream) {
      // Comments
      if (stream.match('#')) {
        stream.skipToEnd();
        return 'comment';
      }
      // Strings
      if (stream.match('"')) {
        while (!stream.eol()) {
          if (stream.next() === '\\') stream.next();
          else if (stream.current().endsWith('"') && stream.current().length > 1) break;
        }
        return 'string';
      }
      // Variables ${...} or $ENV{...} or $CACHE{...}
      if (stream.match(/\$\w*\{/)) {
        while (!stream.eol() && !stream.match('}', true)) stream.next();
        return 'cmakeVariable';
      }
      // Generator expressions $<...>
      if (stream.match('$<')) {
        let depth = 1;
        while (!stream.eol() && depth > 0) {
          const ch = stream.next();
          if (ch === '<') depth++;
          else if (ch === '>') depth--;
        }
        return 'cmakeVariable';
      }
      // Parentheses
      if (stream.match('(') || stream.match(')')) {
        return 'paren';
      }
      // Numbers
      if (stream.match(/\d+(?:\.\d+)?/)) {
        return 'number';
      }
      // Keywords (uppercase identifiers commonly used as keyword args)
      if (stream.match(/[A-Z_][A-Z_0-9]{2,}(?=[\s\)])/)) {
        return 'keyword';
      }
      // Command names (identifiers followed by open paren)
      if (stream.match(/[a-zA-Z_]\w*(?=\s*\()/)) {
        return 'cmakeCommand';
      }
      // Regular identifiers / arguments
      if (stream.match(/[^\s()#"$]+/)) {
        return null;
      }
      // Whitespace
      stream.next();
      return null;
    },
    tokenTable: {
      cmakeCommand: tags.function(tags.variableName),
      cmakeVariable: tags.special(tags.variableName),
    },
  });

  const DEFAULT_SOURCE = `\
CMAKE_MINIMUM_REQUIRED(VERSION 3.20)
PROJECT(MyProject LANGUAGES CXX)

find_package(Boost REQUIRED COMPONENTS filesystem system)

add_library(mylib STATIC
  src/main.cpp
  src/utils.cpp
  src/helper.cpp
)

target_link_libraries(mylib PUBLIC Boost::filesystem Boost::system)
target_include_directories(mylib PUBLIC \${CMAKE_CURRENT_SOURCE_DIR}/include)

# Custom function defined by the project
my_add_test(
  NAME mylib_test
  SOURCES tests/test_main.cpp tests/test_utils.cpp
  LIBRARIES mylib
  TIMEOUT 30
  VERBOSE
)

if(BUILD_TESTING)
  enable_testing()
  add_test(NAME integration COMMAND mylib_test --verbose)
endif()
`;

  // Populated from WASM default_config_yaml() after init. Keep the
  // fallback complete so the config tab is useful before WASM finishes
  // loading, and if WASM fails to load.
  let DEFAULT_CONFIG = `\
# yaml-language-server: $schema=https://cmakefmt.dev/schemas/latest/schema.json
# Default cmakefmt configuration.
# Copy this to .cmakefmt.yaml and uncomment the optional settings
# you want to customize.

format:
  # Disable formatting entirely (return source unchanged).
  # disable: true

  # Output line-ending style: unix (LF), windows (CRLF), or auto (detect from input).
  # line_ending: windows

  # Maximum rendered line width before cmakefmt wraps a call.
  line_width: 80

  # Number of spaces per indentation level when use_tabs is false.
  tab_size: 2

  # Indent with tab characters instead of spaces.
  # use_tabs: true

  # How to handle fractional indentation when use_tabs is true: use-space or round-up.
  # fractional_tab_policy: round-up

  # Maximum number of consecutive blank lines to preserve.
  max_empty_lines: 1

  # Maximum wrapped lines to tolerate before switching to a more vertical layout.
  max_hanging_wrap_lines: 2

  # Maximum positional arguments to keep in a hanging-wrap layout.
  max_hanging_wrap_positional_args: 6

  # Maximum keyword/flag subgroups to keep in a hanging-wrap layout.
  max_hanging_wrap_groups: 2

  # Maximum rows a hanging-wrap positional group may consume before nesting is forced.
  max_rows_cmdline: 2

  # Commands that must always use vertical (wrapped) layout.
  # always_wrap:
  #   - target_link_libraries

  # Return an error if any formatted line exceeds line_width.
  # require_valid_layout: true

  # Keep the first positional argument on the command line when wrapping.
  # wrap_after_first_arg: true

  # Continuation-line alignment when a wrapped keyword section overflows
  # line_width: under-first-value (default, cmake-format hanging-indent) or
  # same-indent (wrap at the keyword's own indent).
  # continuation_align: same-indent

  # Sort arguments in keyword sections marked sortable in the command spec.
  # enable_sort: true

  # Heuristically sort keyword sections where all arguments are simple unquoted tokens.
  # autosort: true

  # Put the closing ')' on its own line when a call wraps.
  dangle_parens: false

  # Alignment strategy for a dangling ')': prefix, open, or close.
  dangle_align: prefix

  # Lower heuristic bound used when deciding between compact and wrapped layouts.
  min_prefix_length: 4

  # Upper heuristic bound used when deciding between compact and wrapped layouts.
  max_prefix_length: 10

  # Insert a space before '(' for control-flow commands like if/foreach.
  # space_before_control_paren: true

  # Insert a space before '(' for function() and macro() definitions.
  # space_before_definition_paren: true

  # Output casing for command names: lower, upper, or unchanged.
  command_case: lower

  # Output casing for recognized keywords and flags: lower, upper, or unchanged.
  keyword_case: upper

markup:
  # Enable markup-aware comment handling.
  enable_markup: true

  # Preserve the first comment block in a file literally.
  first_comment_is_literal: true

  # Preserve comments matching a custom regex literally.
  # literal_comment_pattern: '^\\s*NOTE:'

  # Preferred bullet character when normalizing markup lists.
  bullet_char: '*'

  # Preferred punctuation for numbered lists when normalizing markup.
  enum_char: '.'

  # Regex describing fenced literal comment blocks.
  fence_pattern: '^\\s*[\`~]{3}[^\`\\n]*$'

  # Regex describing ruler-style comments that should be treated specially.
  ruler_pattern: '^[^\\w\\s]{3}.*[^\\w\\s]{3}$'

  # Minimum ruler length before a hash-only line is treated as a ruler.
  hashruler_min_length: 10

  # Normalize ruler comments when markup handling is enabled.
  canonicalize_hashrulers: true

# Uncomment and edit a block like this to override formatting knobs
# for a specific command. This changes layout behavior for that
# command name only; it does not define new command syntax.
#
# per_command_overrides:
#   my_add_test:
#     # Override the line width just for this command.
#     line_width: 120
#
#     # Override command casing just for this command.
#     command_case: unchanged
#
#     # Override keyword casing just for this command.
#     keyword_case: upper
#
#     # Override indentation width just for this command.
#     tab_size: 4
#
#     # Override dangling-paren placement just for this command.
#     dangle_parens: false
#
#     # Override dangling-paren alignment just for this command.
#     dangle_align: prefix
#
#     # Override the positional-argument hanging-wrap threshold just for this command.
#     max_hanging_wrap_positional_args: 8
#
#     # Override the subgroup hanging-wrap threshold just for this command.
#     max_hanging_wrap_groups: 3

# YAML custom-command specs live under commands:<name>. Command
# specs tell the formatter which tokens are positional arguments,
# standalone flags, and keyword sections.
#
# Example: a custom test command with a flag and four keyword sections.
# Uncomment this block to teach cmakefmt the argument structure.
#
# commands:
#   my_add_test:
#     pargs: 0
#     flags:
#       - VERBOSE
#     kwargs:
#       NAME:
#         nargs: 1
#       SOURCES:
#         nargs: "+"
#       LIBRARIES:
#         nargs: "+"
#       TIMEOUT:
#         nargs: 1
`;

  const SOURCE_PRESETS = {
    minimal: DEFAULT_SOURCE,
    install: `\
cmake_minimum_required(VERSION 3.25)
project(InstallDemo LANGUAGES CXX)

add_library(widget SHARED src/widget.cpp src/platform.cpp)

install(TARGETS widget EXPORT WidgetTargets
  RUNTIME DESTINATION bin COMPONENT Runtime
  LIBRARY DESTINATION lib COMPONENT Runtime NAMELINK_COMPONENT Development
  ARCHIVE DESTINATION lib COMPONENT Development
  PUBLIC_HEADER DESTINATION include/widget COMPONENT Development
  FILE_SET HEADERS DESTINATION include/widget COMPONENT Development
)
`,
    comments: `\
# Project-level note that is intentionally long enough to reflow when markup handling is enabled and the configured line width is tight.
cmake_minimum_required(VERSION 3.20)
project(CommentDemo)

#[=[
This bracket comment should stay attached to the following target.
]=]
add_library(commented src/main.cpp src/detail.cpp) # trailing note that will wrap under the comment column

# cmakefmt: off
set(KEEP_THIS   exactly    as-written)
# cmakefmt: on

########################################
# Generated sources
########################################
target_sources(commented PRIVATE generated/a.cpp generated/b.cpp)
`,
    wrapping: `\
cmake_minimum_required(VERSION 3.24)
project(WrapDemo)

target_link_libraries(wrapdemo
  PUBLIC Boost::filesystem Boost::system fmt::fmt spdlog::spdlog range-v3::range-v3
  PRIVATE project_warnings project_options vendor::long_dependency_name
)

set_property(TARGET wrapdemo PROPERTY
  INTERFACE_COMPILE_FEATURES cxx_std_20 cxx_constexpr cxx_lambdas cxx_variadic_templates)
`,
  } as const;

  function withFormatOptions(
    config: string,
    options: Record<string, string | number | boolean>,
  ): string {
    return Object.entries(options).reduce((nextConfig, [key, value]) => {
      const pattern = new RegExp(`^  #?\\s*${key}:.*$`, 'm');
      const replacement = `  ${key}: ${String(value)}`;
      return pattern.test(nextConfig)
        ? nextConfig.replace(pattern, replacement)
        : nextConfig.replace(/^format:\n/m, `format:\n${replacement}\n`);
    }, config);
  }

  const CONFIG_PRESETS = {
    default: () => DEFAULT_CONFIG,
    'custom-command': () => `${DEFAULT_CONFIG.trimEnd()}

commands:
  my_add_test:
    pargs: 0
    flags:
      - VERBOSE
    kwargs:
      NAME:
        nargs: 1
      SOURCES:
        nargs: "+"
      LIBRARIES:
        nargs: "+"
      TIMEOUT:
        nargs: 1
`,
    'cmake-format': () =>
      withFormatOptions(DEFAULT_CONFIG, {
        continuation_align: 'under-first-value',
        dangle_parens: true,
      }),
    wide: () => withFormatOptions(DEFAULT_CONFIG, { line_width: 100 }),
  } as const;

  type SourcePresetName = keyof typeof SOURCE_PRESETS;
  type ConfigPresetName = keyof typeof CONFIG_PRESETS;

  // ── GitHub Dark Default theme for CodeMirror ────────────────────────

  const githubDarkTheme = EditorView.theme({
    '&': {
      backgroundColor: '#0d1117',
      color: '#e6edf3',
    },
    '.cm-gutters': {
      backgroundColor: '#0d1117',
      color: '#6e7681',
      border: 'none',
    },
    '.cm-activeLineGutter': {
      backgroundColor: '#161b22',
    },
    '.cm-activeLine': {
      backgroundColor: '#161b2280',
    },
    '.cm-cursor': {
      borderLeftColor: '#e6edf3',
    },
    '&.cm-focused .cm-selectionBackground, .cm-selectionBackground': {
      backgroundColor: '#264f78',
    },
    '.cm-matchingBracket': {
      backgroundColor: '#3fb95040',
      outline: '1px solid #3fb95080',
    },
  }, { dark: true });

  const githubDarkHighlight = HighlightStyle.define([
    { tag: tags.keyword, color: '#ff7b72' },
    { tag: tags.function(tags.variableName), color: '#d2a8ff' },
    { tag: tags.typeName, color: '#79c0ff' },
    { tag: tags.string, color: '#a5d6ff' },
    { tag: tags.comment, color: '#8b949e' },
    { tag: tags.number, color: '#79c0ff' },
    { tag: tags.bool, color: '#79c0ff' },
    { tag: tags.variableName, color: '#e6edf3' },
    { tag: tags.special(tags.variableName), color: '#ffa657' },
    { tag: tags.operator, color: '#ff7b72' },
    { tag: tags.paren, color: '#e6edf3' },
    { tag: tags.propertyName, color: '#79c0ff' },
    { tag: tags.atom, color: '#79c0ff' },
    { tag: tags.definition(tags.variableName), color: '#ffa657' },
  ], { themeType: 'dark' });

  // GitHub Light Default theme for CodeMirror
  const githubLightTheme = EditorView.theme({
    '&': {
      backgroundColor: '#ffffff',
      color: '#1f2328',
    },
    '.cm-gutters': {
      backgroundColor: '#ffffff',
      color: '#636c76',
      border: 'none',
    },
    '.cm-activeLineGutter': {
      backgroundColor: '#f6f8fa',
    },
    '.cm-activeLine': {
      backgroundColor: '#f6f8fa80',
    },
    '.cm-cursor': {
      borderLeftColor: '#1f2328',
    },
    '&.cm-focused .cm-selectionBackground, .cm-selectionBackground': {
      backgroundColor: '#dbe7f5',
    },
    '.cm-matchingBracket': {
      backgroundColor: '#4ac26b40',
      outline: '1px solid #4ac26b80',
    },
  });

  const githubLightHighlight = HighlightStyle.define([
    { tag: tags.keyword, color: '#cf222e' },
    { tag: tags.function(tags.variableName), color: '#8250df' },
    { tag: tags.typeName, color: '#0550ae' },
    { tag: tags.string, color: '#0a3069' },
    { tag: tags.comment, color: '#6e7781' },
    { tag: tags.number, color: '#0550ae' },
    { tag: tags.bool, color: '#0550ae' },
    { tag: tags.variableName, color: '#1f2328' },
    { tag: tags.special(tags.variableName), color: '#953800' },
    { tag: tags.operator, color: '#cf222e' },
    { tag: tags.paren, color: '#1f2328' },
    { tag: tags.propertyName, color: '#0550ae' },
    { tag: tags.atom, color: '#0550ae' },
    { tag: tags.definition(tags.variableName), color: '#953800' },
  ], { themeType: 'light' });

  function isDarkMode(): boolean {
    return document.documentElement.dataset.theme === 'dark';
  }

  function getEditorTheme() {
    return isDarkMode() ? githubDarkTheme : githubLightTheme;
  }

  // ── Editors ────────────────────────────────────────────────────────

  const sharedExtensions = [
    lineNumbers(),
    highlightActiveLine(),
    highlightActiveLineGutter(),
    bracketMatching(),
    history(),
    keymap.of([indentWithTab, ...defaultKeymap, ...historyKeymap]),
    syntaxHighlighting(githubLightHighlight),
    syntaxHighlighting(githubDarkHighlight),
  ];

  const cmakeExts = [cmakeLanguage];
  const yamlExts = [yaml()];
  const sourceTheme = new Compartment();
  const configTheme = new Compartment();
  const outputTheme = new Compartment();

  const sourceEditor = new EditorView({
    state: EditorState.create({
      doc: DEFAULT_SOURCE,
      extensions: [
        ...sharedExtensions,
        ...cmakeExts,
        sourceTheme.of(getEditorTheme()),
      ],
    }),
    parent: document.getElementById('editor-source')!,
  });

  const configEditor = new EditorView({
    state: EditorState.create({
      doc: DEFAULT_CONFIG,
      extensions: [
        ...sharedExtensions,
        ...yamlExts,
        configTheme.of(getEditorTheme()),
      ],
    }),
    parent: document.getElementById('editor-config')!,
  });

  const outputEditor = new EditorView({
    state: EditorState.create({
      doc: '',
      extensions: [
        lineNumbers(),
        EditorState.readOnly.of(true),
        syntaxHighlighting(githubLightHighlight),
        syntaxHighlighting(githubDarkHighlight),
        ...cmakeExts,
        outputTheme.of(getEditorTheme()),
      ],
    }),
    parent: document.getElementById('editor-output')!,
  });

  // ── Theme sync ─────────────────────────────────────────────────────

  const observer = new MutationObserver(() => {
    sourceEditor.dispatch({
      effects: sourceTheme.reconfigure(getEditorTheme()),
    });
    configEditor.dispatch({
      effects: configTheme.reconfigure(getEditorTheme()),
    });
    outputEditor.dispatch({
      effects: outputTheme.reconfigure(getEditorTheme()),
    });
  });
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });

  // ── Tab switching ──────────────────────────────────────────────────

  const tabs = document.querySelectorAll<HTMLButtonElement>('.playground-tab');
  const sourcePanel = document.getElementById('editor-source')!;
  const configPanel = document.getElementById('editor-config')!;
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      const target = tab.dataset.tab;
      sourcePanel.hidden = target !== 'source';
      configPanel.hidden = target !== 'config';
    });
  });

  // ── WASM loading ───────────────────────────────────────────────────

  const statusEl = document.getElementById('playground-status')!;
  const formatBtn = document.getElementById('btn-format') as HTMLButtonElement;
  const resetBtn = document.getElementById('btn-reset') as HTMLButtonElement;
  const copyBtn = document.getElementById('btn-copy') as HTMLButtonElement;
  const shareBtn = document.getElementById('btn-share') as HTMLButtonElement;
  const sourcePresetSelect = document.getElementById('source-preset') as HTMLSelectElement;
  const configPresetSelect = document.getElementById('config-preset') as HTMLSelectElement;

  let wasmFormat: ((source: string, config: string) => string) | null = null;

  async function loadWasmModule(): Promise<any> {
    // Vite blocks import() of /public files during dev. Work around this by
    // creating a module script that re-exports the WASM glue at runtime.
    const blob = new Blob(
      [`export * from "${new URL('/wasm/cmakefmt.js', window.location.origin).href}";
        export { default } from "${new URL('/wasm/cmakefmt.js', window.location.origin).href}";`],
      { type: 'text/javascript' },
    );
    const blobUrl = URL.createObjectURL(blob);
    try {
      const mod = await import(/* @vite-ignore */ blobUrl);
      await mod.default();
      return mod;
    } finally {
      URL.revokeObjectURL(blobUrl);
    }
  }

  async function initWasm() {
    try {
      const wasm = await loadWasmModule();
      wasmFormat = wasm.format;

      // Use the same default config as `cmakefmt config dump`.
      if (typeof wasm.default_config_yaml === 'function') {
        DEFAULT_CONFIG = wasm.default_config_yaml();
        replaceDocument(
          configEditor,
          CONFIG_PRESETS[configPresetSelect.value as ConfigPresetName](),
        );
      }

      statusEl.textContent = 'Ready';
      statusEl.classList.add('ready');
      formatBtn.disabled = false;

      // Try restoring from URL hash (may override the default config).
      restoreFromHash();

      // Auto-format on load, including any preset selected before WASM finished.
      requestFormat();

    } catch (e) {
      statusEl.textContent = `Failed to load WASM: ${e}`;
      statusEl.classList.add('error');
    }
  }

  // ── Format ─────────────────────────────────────────────────────────

  function doFormat() {
    if (!wasmFormat) return;

    const source = sourceEditor.state.doc.toString();
    const configStr = configEditor.state.doc.toString();

    try {
      const result = wasmFormat(source, configStr);
      outputEditor.dispatch({
        changes: {
          from: 0,
          to: outputEditor.state.doc.length,
          insert: result,
        },
      });
      statusEl.textContent = 'Formatted';
      statusEl.classList.remove('error');
      statusEl.classList.add('ready');
    } catch (e) {
      outputEditor.dispatch({
        changes: {
          from: 0,
          to: outputEditor.state.doc.length,
          insert: `Error: ${e}`,
        },
      });
      statusEl.textContent = `Error`;
      statusEl.classList.remove('ready');
      statusEl.classList.add('error');
    }
  }

  formatBtn.addEventListener('click', doFormat);

  // ── Presets and share URLs ─────────────────────────────────────────

  function replaceDocument(editor: EditorView, text: string) {
    editor.dispatch({
      changes: { from: 0, to: editor.state.doc.length, insert: text },
    });
  }

  function requestFormat() {
    if (!wasmFormat) {
      return;
    }

    doFormat();
  }

  function encodeState() {
    const payload = JSON.stringify({
      source: sourceEditor.state.doc.toString(),
      config: configEditor.state.doc.toString(),
      sourcePreset: sourcePresetSelect.value,
      configPreset: configPresetSelect.value,
    });

    return btoa(unescape(encodeURIComponent(payload)));
  }

  function decodeState(hash: string) {
    const json = decodeURIComponent(escape(atob(hash)));
    return JSON.parse(json) as {
      source?: string;
      config?: string;
      sourcePreset?: string;
      configPreset?: string;
    };
  }

  function writeShareHash() {
    const url = `${window.location.pathname}${window.location.search}#${encodeState()}`;
    window.history.replaceState(null, '', url);
    return window.location.href;
  }

  function clearShareHash() {
    window.history.replaceState(null, '', `${window.location.pathname}${window.location.search}`);
  }

  function setPresetSelectionFromDocument() {
    const source = sourceEditor.state.doc.toString();
    const config = configEditor.state.doc.toString();
    const sourceMatch = Object.entries(SOURCE_PRESETS).find(([, value]) => value === source);
    const configMatch = Object.entries(CONFIG_PRESETS).find(([, value]) => value() === config);

    sourcePresetSelect.value = sourceMatch?.[0] ?? 'minimal';
    configPresetSelect.value = configMatch?.[0] ?? 'default';
  }

  sourcePresetSelect.addEventListener('change', () => {
    const preset = sourcePresetSelect.value as SourcePresetName;
    replaceDocument(sourceEditor, SOURCE_PRESETS[preset]);
    writeShareHash();
    requestFormat();
  });

  configPresetSelect.addEventListener('change', () => {
    const preset = configPresetSelect.value as ConfigPresetName;
    replaceDocument(configEditor, CONFIG_PRESETS[preset]());
    writeShareHash();
    requestFormat();
  });

  shareBtn.addEventListener('click', async () => {
    const url = writeShareHash();

    try {
      await navigator.clipboard.writeText(url);
      shareBtn.textContent = 'Shared!';
      setTimeout(() => {
        shareBtn.textContent = 'Share';
      }, 1500);
    } catch {
      shareBtn.textContent = 'Linked';
      setTimeout(() => {
        shareBtn.textContent = 'Share';
      }, 1500);
    }
  });

  // ── Reset ──────────────────────────────────────────────────────────

  resetBtn.addEventListener('click', () => {
    sourcePresetSelect.value = 'minimal';
    configPresetSelect.value = 'default';
    replaceDocument(sourceEditor, DEFAULT_SOURCE);
    replaceDocument(configEditor, DEFAULT_CONFIG);
    replaceDocument(outputEditor, '');
    statusEl.textContent = 'Reset';
    clearShareHash();
  });

  function restoreFromHash() {
    const hash = window.location.hash.slice(1);
    if (!hash) return;
    try {
      const state = decodeState(hash);
      if (typeof state.source === 'string') {
        replaceDocument(sourceEditor, state.source);
      }
      if (typeof state.config === 'string') {
        replaceDocument(configEditor, state.config);
      }
      if (state.sourcePreset && state.sourcePreset in SOURCE_PRESETS) {
        sourcePresetSelect.value = state.sourcePreset;
      }
      if (state.configPreset && state.configPreset in CONFIG_PRESETS) {
        configPresetSelect.value = state.configPreset;
      }
      setPresetSelectionFromDocument();
    } catch {
      // Invalid hash, ignore
    }
  }

  // ── Copy ───────────────────────────────────────────────────────────

  copyBtn.addEventListener('click', async () => {
    const text = outputEditor.state.doc.toString();
    try {
      await navigator.clipboard.writeText(text);
      copyBtn.textContent = 'Copied!';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
    } catch {
      // Fallback
      copyBtn.textContent = 'Failed';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
    }
  });

  // ── Init ───────────────────────────────────────────────────────────

  initWasm();
</script>


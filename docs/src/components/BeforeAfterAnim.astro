// Animated before/after code transformation with syntax highlighting.
---

<div class="ba-anim" id="ba-anim">
  <div class="ba-anim-header">
    <span class="ba-anim-label" id="ba-anim-label">Before</span>
    <button class="ba-anim-btn" id="ba-anim-replay">Replay</button>
  </div>
  <div class="ba-anim-code" id="ba-anim-code"></div>
</div>

<style>
  .ba-anim {
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 30%, transparent);
    background: color-mix(in srgb, var(--sl-color-gray-6) 80%, transparent);
    backdrop-filter: blur(8px);
    overflow: hidden;
    margin: 1.5rem 0;
  }

  .ba-anim-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 20%, transparent);
  }

  .ba-anim-label {
    font-family: var(--sl-font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-3);
    transition: color 0.3s ease;
  }

  .ba-anim-label.formatted {
    color: var(--sl-color-text-accent);
  }

  .ba-anim-btn {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    background: none;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 9999px;
    padding: 0.2rem 0.625rem;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .ba-anim-btn:hover {
    color: var(--sl-color-text-accent);
    border-color: var(--sl-color-accent);
  }

  .ba-anim-code {
    font-family: var(--sl-font-mono);
    font-size: 0.8125rem;
    line-height: 1.7;
    padding: 1rem 1.25rem;
    min-height: 12em;
    overflow-x: auto;
    white-space: pre;
    transition: opacity 0.35s ease;
  }

  .ba-anim-code :global(.ba-line) {
    display: block;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .ba-anim-code :global(.ba-line.entering) {
    opacity: 0;
    transform: translateX(-8px);
  }

  /* Token colours */
  .ba-anim-code :global(.tok-cmd) { color: hsl(200, 85%, 55%); }
  .ba-anim-code :global(.tok-kw) { color: hsl(280, 60%, 65%); }
  .ba-anim-code :global(.tok-str) { color: hsl(140, 55%, 55%); }
  .ba-anim-code :global(.tok-num) { color: hsl(30, 80%, 60%); }
  .ba-anim-code :global(.tok-comment) { color: var(--sl-color-gray-3); font-style: italic; }
  .ba-anim-code :global(.tok-paren) { color: var(--sl-color-gray-2); }
  .ba-anim-code :global(.tok-var) { color: hsl(35, 85%, 60%); }
  .ba-anim-code :global(.tok-plain) { color: var(--sl-color-gray-1); }
</style>

<script>
  // ── Simple CMake tokenizer ──────────────────────────────────────
  type Token = { text: string; cls: string };

  function tokenizeLine(line: string): Token[] {
    const tokens: Token[] = [];
    let i = 0;

    while (i < line.length) {
      if (/\s/.test(line[i])) {
        let start = i;
        while (i < line.length && /\s/.test(line[i])) i++;
        tokens.push({ text: line.slice(start, i), cls: '' });
        continue;
      }
      if (line[i] === '#') {
        tokens.push({ text: line.slice(i), cls: 'tok-comment' });
        break;
      }
      if (line[i] === '"') {
        let start = i; i++;
        while (i < line.length && line[i] !== '"') {
          if (line[i] === '\\') i++;
          i++;
        }
        if (i < line.length) i++;
        tokens.push({ text: line.slice(start, i), cls: 'tok-str' });
        continue;
      }
      if (line[i] === '$' && i + 1 < line.length && /[\w{]/.test(line[i + 1])) {
        let start = i; i++;
        while (i < line.length && line[i] !== '}') i++;
        if (i < line.length) i++;
        tokens.push({ text: line.slice(start, i), cls: 'tok-var' });
        continue;
      }
      if (line[i] === '(' || line[i] === ')') {
        tokens.push({ text: line[i], cls: 'tok-paren' }); i++;
        continue;
      }
      const numMatch = line.slice(i).match(/^\d+(\.\d+)?/);
      if (numMatch && (i === 0 || /[\s(]/.test(line[i - 1]))) {
        tokens.push({ text: numMatch[0], cls: 'tok-num' });
        i += numMatch[0].length;
        continue;
      }
      let start = i;
      while (i < line.length && /[^\s()#"$]/.test(line[i])) i++;
      const word = line.slice(start, i);
      const rest = line.slice(i).trimStart();
      if (rest.startsWith('(')) {
        tokens.push({ text: word, cls: 'tok-cmd' });
      } else if (/^[A-Z_][A-Z_0-9]{2,}$/.test(word)) {
        tokens.push({ text: word, cls: 'tok-kw' });
      } else {
        tokens.push({ text: word, cls: 'tok-plain' });
      }
    }
    return tokens;
  }

  function renderLine(line: string, entering = false): HTMLElement {
    const span = document.createElement('span');
    span.className = 'ba-line' + (entering ? ' entering' : '');
    if (line === '') {
      span.appendChild(document.createTextNode('\n'));
      return span;
    }
    for (const tok of tokenizeLine(line)) {
      if (tok.cls) {
        const s = document.createElement('span');
        s.className = tok.cls;
        s.textContent = tok.text;
        span.appendChild(s);
      } else {
        span.appendChild(document.createTextNode(tok.text));
      }
    }
    span.appendChild(document.createTextNode('\n'));
    return span;
  }

  function clearElement(el: HTMLElement) {
    while (el.firstChild) el.removeChild(el.firstChild);
  }

  // ── Before/after source ─────────────────────────────────────────
  const beforeSrc = `CMAKE_MINIMUM_REQUIRED(VERSION 3.20)
Project(myproject LANGUAGES CXX)

set(SOURCES src/main.cpp
src/utils.cpp
  src/parser.cpp)

target_link_libraries(mylib PUBLIC
Boost::filesystem Boost::system    fmt::fmt
  PRIVATE
    spdlog::spdlog)

IF(WIN32)
MESSAGE(STATUS "building on Windows")
ENDIF()`;

  const afterSrc = `cmake_minimum_required(VERSION 3.20)
project(myproject LANGUAGES CXX)

set(SOURCES src/main.cpp src/utils.cpp src/parser.cpp)

target_link_libraries(
  mylib
  PUBLIC Boost::filesystem Boost::system fmt::fmt
  PRIVATE spdlog::spdlog)

if(WIN32)
  message(STATUS "building on Windows")
endif()`;

  // ── Animation ───────────────────────────────────────────────────
  const codeEl = document.getElementById('ba-anim-code');
  const labelEl = document.getElementById('ba-anim-label');
  const replayBtn = document.getElementById('ba-anim-replay');
  const container = document.getElementById('ba-anim');

  function showBefore() {
    if (!codeEl || !labelEl) return;
    clearElement(codeEl);
    labelEl.textContent = 'Before';
    labelEl.classList.remove('formatted');
    for (const line of beforeSrc.split('\n')) {
      codeEl.appendChild(renderLine(line));
    }
  }

  function animateToAfter() {
    if (!codeEl || !labelEl) return;
    labelEl.textContent = 'Formatting…';
    codeEl.style.opacity = '0.3';

    setTimeout(() => {
      clearElement(codeEl);
      const afterLines = afterSrc.split('\n');

      for (let i = 0; i < afterLines.length; i++) {
        const lineEl = renderLine(afterLines[i], true);
        codeEl.appendChild(lineEl);
        setTimeout(() => {
          lineEl.classList.remove('entering');
        }, i * 40);
      }

      codeEl.style.opacity = '1';
      labelEl.textContent = 'After';
      labelEl.classList.add('formatted');
    }, 500);
  }

  function run() {
    showBefore();
    setTimeout(animateToAfter, 2200);
  }

  replayBtn?.addEventListener('click', run);

  if (container) {
    const obs = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        run();
        obs.disconnect();
      }
    }, { threshold: 0.3 });
    obs.observe(container);
  }
</script>

// Animated dot grid with radial wave pulse — renders behind the hero.
---

<script>
  // Create the canvas and inject it into the .hero element
  const hero = document.querySelector('.hero');
  if (hero) {
    const canvas = document.createElement('canvas');
    canvas.id = 'dot-grid-canvas';
    canvas.setAttribute('aria-hidden', 'true');
    canvas.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;z-index:-2;pointer-events:none;';
    hero.prepend(canvas);

    const ctx = canvas.getContext('2d')!;
    const gap = 24;
    const baseRadius = 0.8;
    const maxExtraRadius = 0.5;
    const waveSpeed = 0.0003;
    const waveLength = 400;

    let animId: number;

    function resize() {
      const rect = canvas.parentElement?.getBoundingClientRect();
      if (!rect) return;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = `${rect.width}px`;
      canvas.style.height = `${rect.height}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function draw(time: number) {
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      ctx.clearRect(0, 0, w, h);

      // Centre of the wave pulse
      const cx = w / 2;
      const cy = h * 0.4;

      // Wave ring expands outward from centre
      const waveRadius = ((time * waveSpeed) % 1) * Math.max(w, h) * 1.2;

      const isDark = document.documentElement.dataset.theme === 'dark';
      const dotColor = isDark ? 'rgba(255,255,255,' : 'rgba(120,120,130,';

      // Fade mask: dots fade out toward edges
      const maxDist = Math.hypot(w / 2, h / 2);

      for (let x = gap / 2; x < w; x += gap) {
        for (let y = gap / 2; y < h; y += gap) {
          const dist = Math.hypot(x - cx, y - cy);

          // Radial fade — dots near edges are dimmer
          const fadeFactor = 1 - Math.min(dist / maxDist, 1);
          const fade = fadeFactor * fadeFactor; // quadratic falloff

          // Wave: dots near the wave ring get bigger — double smoothstep
          // for a gentle ramp up and down with no harsh edges
          const waveDelta = Math.abs(dist - waveRadius);
          const waveInfluence = Math.max(0, 1 - waveDelta / waveLength);
          const s = waveInfluence * waveInfluence * (3 - 2 * waveInfluence);
          const eased = s * s * (3 - 2 * s);

          const r = baseRadius + eased * maxExtraRadius;
          const alpha = (0.18 + eased * 0.15) * fade;

          if (alpha < 0.02) continue;

          ctx.beginPath();
          ctx.arc(x, y, r, 0, Math.PI * 2);
          ctx.fillStyle = `${dotColor}${alpha})`;
          ctx.fill();
        }
      }

      animId = requestAnimationFrame(draw);
    }

    resize();
    animId = requestAnimationFrame(draw);
    window.addEventListener('resize', resize);

    // Pause when off-screen
    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        animId = requestAnimationFrame(draw);
      } else {
        cancelAnimationFrame(animId);
      }
    });
    observer.observe(canvas);
  }
</script>

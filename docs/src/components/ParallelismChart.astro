<div class="chart-wrapper" data-parallelism-chart>
  <canvas id="parallelism-chart" aria-label="Parallelism scaling: time vs worker count for 282-file and 611-file batches"></canvas>
</div>

<script>
import { Chart, LineController, LineElement, PointElement, CategoryScale, LinearScale, Tooltip, Legend } from 'chart.js';
Chart.register(LineController, LineElement, PointElement, CategoryScale, LinearScale, Tooltip, Legend);

// Time in ms for each worker count
const OPENCV_282 = [
  { workers: 'serial', ms: 102 },
  { workers: '--parallel 2', ms: 71 },
  { workers: '--parallel 4', ms: 49 },
  { workers: '--parallel 8', ms: 36 },
];

const OOMPH_611 = [
  { workers: 'serial', ms: 144 },
  { workers: '--parallel 2', ms: 107 },
  { workers: '--parallel 4', ms: 78 },
  { workers: '--parallel 8', ms: 61 },
];

function isDark() {
  return document.documentElement.dataset.theme === 'dark';
}

function colors() {
  const dark = isDark();
  return {
    line1:    dark ? 'hsl(198,93%,60%)' : 'hsl(200,98%,39%)',
    line2:    dark ? 'hsl(38,92%,60%)'  : 'hsl(38,92%,44%)',
    grid:     dark ? 'hsl(240,4%,20%)'  : 'hsl(240,6%,90%)',
    text:     dark ? 'hsl(0,0%,100%)'   : 'hsl(240,6%,10%)',
    subtext:  dark ? 'hsl(240,5%,65%)'  : 'hsl(240,4%,46%)',
  };
}

function buildChart(canvas: HTMLCanvasElement) {
  const c = colors();
  Chart.getChart(canvas)?.destroy();

  new Chart(canvas, {
    type: 'line',
    data: {
      labels: OPENCV_282.map(d => d.workers),
      datasets: [
        {
          label: 'opencv (282 files)',
          data: OPENCV_282.map(d => d.ms),
          borderColor: c.line1,
          backgroundColor: c.line1 + '22',
          pointBackgroundColor: c.line1,
          pointRadius: 5,
          pointHoverRadius: 7,
          fill: false,
          tension: 0.3,
        },
        {
          label: 'oomph-lib (611 files)',
          data: OOMPH_611.map(d => d.ms),
          borderColor: c.line2,
          backgroundColor: c.line2 + '22',
          pointBackgroundColor: c.line2,
          pointRadius: 5,
          pointHoverRadius: 7,
          fill: false,
          tension: 0.3,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      interaction: {
        mode: 'index',
        intersect: false,
      },
      scales: {
        x: {
          ticks: { color: c.subtext, font: { size: 12 } },
          grid: { color: c.grid },
          border: { color: c.grid },
        },
        y: {
          title: {
            display: true,
            text: 'Time (ms)',
            color: c.subtext,
            font: { size: 11 },
          },
          min: 0,
          ticks: {
            color: c.subtext,
            font: { size: 11 },
            callback: (v) => `${v} ms`,
          },
          grid: { color: c.grid },
          border: { color: c.grid },
        },
      },
      plugins: {
        legend: {
          labels: {
            color: c.text,
            font: { size: 12 },
            boxWidth: 12,
            boxHeight: 12,
          },
        },
        tooltip: {
          backgroundColor: isDark() ? 'hsl(240,6%,14%)' : 'hsl(0,0%,100%)',
          borderColor: isDark() ? 'hsl(240,4%,24%)' : 'hsl(240,6%,90%)',
          borderWidth: 1,
          titleColor: c.text,
          bodyColor: c.subtext,
          padding: 10,
          callbacks: {
            label: (item) => {
              const serialMs = item.datasetIndex === 0 ? OPENCV_282[0].ms : OOMPH_611[0].ms;
              const speedup = (serialMs / (item.raw as number)).toFixed(2);
              const label = item.datasetIndex === 0 ? '282-file batch' : '611-file batch';
              return [
                `  ${label}: ${(item.raw as number).toFixed(1)} ms`,
                `  ${speedup}× faster than serial`,
              ];
            },
          },
        },
      },
    },
  });
}

function initParallelismCharts() {
  document.querySelectorAll('[data-parallelism-chart]').forEach((wrapper) => {
    if (!(wrapper instanceof HTMLDivElement)) {
      return;
    }

    const canvas = wrapper.querySelector('#parallelism-chart');
    if (!(canvas instanceof HTMLCanvasElement)) {
      return;
    }

    buildChart(canvas);
  });
}

const parallelismChartWindow = window as Window & {
  __parallelismChartsRegistered?: boolean;
};

if (!parallelismChartWindow.__parallelismChartsRegistered) {
  parallelismChartWindow.__parallelismChartsRegistered = true;
  document.addEventListener('astro:page-load', initParallelismCharts);

  const observer = new MutationObserver(() => initParallelismCharts());
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });
}

initParallelismCharts();
</script>

<style>
  .chart-wrapper {
    position: relative;
    width: 100%;
    max-width: 680px;
    margin: 1.5rem auto;
    border: 1px solid var(--sl-color-hairline, hsl(240, 6%, 90%));
    border-radius: 0.75rem;
    padding: 1.5rem 1rem 1rem;
    background: color-mix(in srgb, var(--sl-color-accent-low, hsl(200, 98%, 95%)) 10%, transparent);
  }
</style>

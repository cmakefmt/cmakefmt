<div class="chart-wrapper" data-benchmark-comparison-chart>
  <div class="chart-controls">
    <label class="toggle-label" title="Switch y-axis scale">
      <span class="scale-label">Linear</span>
      <input type="checkbox" id="scale-toggle" class="toggle toggle-sm" />
      <span class="scale-label">Log</span>
    </label>
  </div>
  <canvas
    id="benchmark-comparison-chart"
    aria-label="cmakefmt vs cmake-format per-fixture timing comparison"></canvas>
</div>

<script>
  import {
    Chart,
    BarController,
    BarElement,
    CategoryScale,
    LinearScale,
    LogarithmicScale,
    Tooltip,
    Legend,
  } from "chart.js";
  Chart.register(
    BarController,
    BarElement,
    CategoryScale,
    LinearScale,
    LogarithmicScale,
    Tooltip,
    Legend,
  );

  const DATA = [
    { label: "opencv_flann", lines: 2, cmakefmt: 6.3, legacy: 55.8, speedup: 8.9 },
    { label: "googletest", lines: 36, cmakefmt: 5.4, legacy: 68.2, speedup: 12.6 },
    { label: "llvm_tablegen", lines: 83, cmakefmt: 6.4, legacy: 83.8, speedup: 13.1 },
    { label: "abseil", lines: 280, cmakefmt: 6.8, legacy: 186.1, speedup: 27.4 },
    { label: "spdlog", lines: 413, cmakefmt: 7.7, legacy: 239.1, speedup: 31.1 },
    { label: "mariadb_server", lines: 656, cmakefmt: 7.1, legacy: 532.0, speedup: 75.0 },
    { label: "xnnpack", lines: 1354, cmakefmt: 8.6, legacy: 1568.9, speedup: 182.2 },
    { label: "opencv_root", lines: 2039, cmakefmt: 9.8, legacy: 43158.4, speedup: 4417.2 },
    { label: "blender_root", lines: 2650, cmakefmt: 8.6, legacy: 2922.7, speedup: 338.5 },
    { label: "llvm_libc_math", lines: 6688, cmakefmt: 8.9, legacy: 2473.7, speedup: 279.3 },
    { label: "grpc_root", lines: 54834, cmakefmt: 39.4, legacy: 84489.2, speedup: 2146.2 },
  ];

  function isDark() {
    return document.documentElement.dataset.theme === "dark";
  }

  function colors() {
    const dark = isDark();
    return {
      cmakefmt: dark ? "hsl(198,93%,60%)" : "hsl(200,98%,39%)",
      cmakefmtHover: dark ? "hsl(198,93%,70%)" : "hsl(200,98%,28%)",
      legacy: dark ? "hsl(240,4%,40%)" : "hsl(240,5%,72%)",
      legacyHover: dark ? "hsl(240,4%,50%)" : "hsl(240,5%,60%)",
      grid: dark ? "hsl(240,4%,20%)" : "hsl(240,6%,90%)",
      text: dark ? "hsl(0,0%,100%)" : "hsl(240,6%,10%)",
      subtext: dark ? "hsl(240,5%,65%)" : "hsl(240,4%,46%)",
    };
  }

  function buildChart(canvas: HTMLCanvasElement, logScale: boolean) {
    const c = colors();
    Chart.getChart(canvas)?.destroy();

    new Chart(canvas, {
      type: "bar",
      data: {
        labels: DATA.map((d) => d.label),
        datasets: [
          {
            label: "cmake-format",
            data: DATA.map((d) => d.legacy),
            backgroundColor: c.legacy,
            hoverBackgroundColor: c.legacyHover,
            borderRadius: 3,
            borderSkipped: false,
          },
          {
            label: "cmakefmt",
            data: DATA.map((d) => d.cmakefmt),
            backgroundColor: c.cmakefmt,
            hoverBackgroundColor: c.cmakefmtHover,
            borderRadius: 3,
            borderSkipped: false,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        interaction: {
          mode: "index",
          intersect: false,
        },
        scales: {
          x: {
            ticks: {
              color: c.subtext,
              font: { size: 11 },
              maxRotation: 35,
              minRotation: 35,
            },
            grid: { color: c.grid },
            border: { color: c.grid },
          },
          y: {
            type: logScale ? "logarithmic" : "linear",
            title: {
              display: true,
              text: logScale ? "Time (ms, log scale)" : "Time (ms)",
              color: c.subtext,
              font: { size: 11 },
            },
            ticks: {
              color: c.subtext,
              font: { size: 11 },
              callback: (v) => {
                if (logScale) {
                  const log = Math.log10(Number(v));
                  return Math.abs(log - Math.round(log)) < 1e-9 ? `${v} ms` : null;
                }
                return `${v} ms`;
              },
            },
            grid: { color: c.grid },
            border: { color: c.grid },
          },
        },
        plugins: {
          legend: {
            labels: {
              color: c.text,
              font: { size: 12 },
              boxWidth: 12,
              boxHeight: 12,
              useBorderRadius: true,
            },
          },
          tooltip: {
            backgroundColor: isDark() ? "hsl(240,6%,14%)" : "hsl(0,0%,100%)",
            borderColor: isDark() ? "hsl(240,4%,24%)" : "hsl(240,6%,90%)",
            borderWidth: 1,
            titleColor: c.text,
            bodyColor: c.subtext,
            padding: 10,
            callbacks: {
              title: (items) => {
                const d = DATA[items[0].dataIndex];
                return `${d.label}  (${d.lines} lines)`;
              },
              label: (item) => {
                const d = DATA[item.dataIndex];
                if (item.datasetIndex === 0) {
                  return [
                    `  cmakefmt:      ${d.cmakefmt.toFixed(3)} ms`,
                    `  speedup:       ${d.speedup}×`,
                  ];
                }
                return `  cmake-format:  ${d.legacy.toFixed(3)} ms`;
              },
            },
          },
        },
      },
    });
  }

  function initBenchmarkComparisonCharts() {
    document.querySelectorAll("[data-benchmark-comparison-chart]").forEach((wrapper) => {
      if (!(wrapper instanceof HTMLDivElement)) {
        return;
      }

      const canvas = wrapper.querySelector("#benchmark-comparison-chart");
      const toggle = wrapper.querySelector("#scale-toggle");
      if (!(canvas instanceof HTMLCanvasElement) || !(toggle instanceof HTMLInputElement)) {
        return;
      }

      if (toggle.dataset.chartBound !== "true") {
        toggle.addEventListener("change", () => initBenchmarkComparisonCharts());
        toggle.dataset.chartBound = "true";
      }

      buildChart(canvas, toggle.checked);
    });
  }

  const benchmarkComparisonWindow = window as Window & {
    __benchmarkComparisonChartsRegistered?: boolean;
  };

  if (!benchmarkComparisonWindow.__benchmarkComparisonChartsRegistered) {
    benchmarkComparisonWindow.__benchmarkComparisonChartsRegistered = true;
    document.addEventListener("astro:page-load", initBenchmarkComparisonCharts);

    const observer = new MutationObserver(() => initBenchmarkComparisonCharts());
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
  }

  initBenchmarkComparisonCharts();
</script>

<style>
  .chart-wrapper {
    position: relative;
    width: 100%;
    max-width: 860px;
    margin: 1.5rem auto;
    border: 1px solid var(--sl-color-hairline, hsl(240, 6%, 90%));
    border-radius: 0.75rem;
    padding: 1.5rem 1rem 1rem;
    background: color-mix(in srgb, var(--sl-color-accent-low, hsl(200, 98%, 95%)) 10%, transparent);
  }

  .chart-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .scale-label {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3, hsl(240, 4%, 46%));
  }

  .toggle-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
  }

  /* Accent border in both states */
  .toggle {
    --input-color: var(--sl-color-accent, hsl(200, 98%, 39%));
  }

  /* Filled accent track when checked; border stays accent via --input-color */
  .toggle:checked,
  .toggle[aria-checked="true"] {
    background-color: var(--sl-color-accent, hsl(200, 98%, 39%));
  }

  /* White thumb on the filled blue background */
  .toggle:checked::before,
  .toggle[aria-checked="true"]::before {
    background-color: #fff;
  }
</style>

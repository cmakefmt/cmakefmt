---

<div class="chart-wrapper">
  <div class="chart-controls">
    <span class="scale-label">Scale</span>
    <div class="scale-toggle" role="group" aria-label="Y-axis scale">
      <button id="btn-linear" class="scale-btn active" type="button">Linear</button>
      <button id="btn-log"    class="scale-btn"        type="button">Log</button>
    </div>
  </div>
  <canvas
    id="benchmark-comparison-chart"
    aria-label="cmakefmt vs cmake-format per-fixture timing comparison"></canvas>
</div>

<script>
  import {
    Chart,
    BarController,
    BarElement,
    CategoryScale,
    LinearScale,
    LogarithmicScale,
    Tooltip,
    Legend,
  } from "chart.js";
  Chart.register(
    BarController,
    BarElement,
    CategoryScale,
    LinearScale,
    LogarithmicScale,
    Tooltip,
    Legend,
  );

  const DATA = [
    { label: "abseil",         lines: 280,  cmakefmt: 5.358,  legacy: 172.882,  speedup: 32.27 },
    { label: "catch2",         lines: 230,  cmakefmt: 5.177,  legacy: 110.495,  speedup: 21.34 },
    { label: "cli11",          lines: 283,  cmakefmt: 5.174,  legacy: 125.992,  speedup: 24.35 },
    { label: "cmake_cmbzip2",  lines: 25,   cmakefmt: 4.563,  legacy: 63.034,   speedup: 13.81 },
    { label: "googletest",     lines: 36,   cmakefmt: 4.376,  legacy: 65.244,   speedup: 14.91 },
    { label: "ggml",           lines: 498,  cmakefmt: 7.371,  legacy: 216.193,  speedup: 29.33 },
    { label: "llama_cpp",      lines: 286,  cmakefmt: 5.755,  legacy: 131.230,  speedup: 22.80 },
    { label: "llvm_tablegen",  lines: 83,   cmakefmt: 4.439,  legacy: 79.608,   speedup: 17.93 },
    { label: "mariadb_server", lines: 656,  cmakefmt: 9.097,  legacy: 489.035,  speedup: 53.76 },
    { label: "nlohmann_json",  lines: 237,  cmakefmt: 5.035,  legacy: 140.580,  speedup: 27.92 },
    { label: "opencv_flann",   lines: 2,    cmakefmt: 4.263,  legacy: 54.812,   speedup: 12.86 },
    { label: "protobuf",       lines: 351,  cmakefmt: 5.478,  legacy: 114.711,  speedup: 20.94 },
    { label: "spdlog",         lines: 413,  cmakefmt: 6.461,  legacy: 220.804,  speedup: 34.17 },
    { label: "qtbase_network", lines: 420,  cmakefmt: 7.852,  legacy: 293.745,  speedup: 37.41 },
    { label: "xnnpack",        lines: 1354, cmakefmt: 26.965, legacy: 1432.939, speedup: 53.14 },
  ];

  function isDark() {
    return document.documentElement.dataset.theme === "dark";
  }

  function colors() {
    const dark = isDark();
    return {
      cmakefmt:     dark ? "hsl(198,93%,60%)" : "hsl(200,98%,39%)",
      cmakefmtHover:dark ? "hsl(198,93%,70%)" : "hsl(200,98%,28%)",
      legacy:       dark ? "hsl(240,4%,40%)"  : "hsl(240,5%,72%)",
      legacyHover:  dark ? "hsl(240,4%,50%)"  : "hsl(240,5%,60%)",
      grid:         dark ? "hsl(240,4%,20%)"  : "hsl(240,6%,90%)",
      text:         dark ? "hsl(0,0%,100%)"   : "hsl(240,6%,10%)",
      subtext:      dark ? "hsl(240,5%,65%)"  : "hsl(240,4%,46%)",
    };
  }

  const canvas = document.getElementById("benchmark-comparison-chart") as HTMLCanvasElement;
  const btnLinear = document.getElementById("btn-linear") as HTMLButtonElement;
  const btnLog    = document.getElementById("btn-log")    as HTMLButtonElement;

  let chart: Chart | null = null;
  let logScale = false;

  function buildChart() {
    const c = colors();
    if (chart) chart.destroy();

    chart = new Chart(canvas, {
      type: "bar",
      data: {
        labels: DATA.map((d) => d.label),
        datasets: [
          {
            label: "cmake-format",
            data: DATA.map((d) => d.legacy),
            backgroundColor: c.legacy,
            hoverBackgroundColor: c.legacyHover,
            borderRadius: 3,
            borderSkipped: false,
          },
          {
            label: "cmakefmt",
            data: DATA.map((d) => d.cmakefmt),
            backgroundColor: c.cmakefmt,
            hoverBackgroundColor: c.cmakefmtHover,
            borderRadius: 3,
            borderSkipped: false,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        interaction: {
          mode: "index",
          intersect: false,
        },
        scales: {
          x: {
            ticks: {
              color: c.subtext,
              font: { size: 11 },
              maxRotation: 35,
              minRotation: 35,
            },
            grid:   { color: c.grid },
            border: { color: c.grid },
          },
          y: {
            type: logScale ? "logarithmic" : "linear",
            title: {
              display: true,
              text: logScale ? "Time (ms, log scale)" : "Time (ms)",
              color: c.subtext,
              font: { size: 11 },
            },
            ticks: {
              color: c.subtext,
              font: { size: 11 },
              callback: (v) => `${v} ms`,
            },
            grid:   { color: c.grid },
            border: { color: c.grid },
          },
        },
        plugins: {
          legend: {
            labels: {
              color: c.text,
              font: { size: 12 },
              boxWidth: 12,
              boxHeight: 12,
            },
          },
          tooltip: {
            backgroundColor: isDark() ? "hsl(240,6%,14%)" : "hsl(0,0%,100%)",
            borderColor:     isDark() ? "hsl(240,4%,24%)" : "hsl(240,6%,90%)",
            borderWidth: 1,
            titleColor: c.text,
            bodyColor:  c.subtext,
            padding: 10,
            callbacks: {
              title: (items) => {
                const d = DATA[items[0].dataIndex];
                return `${d.label}  (${d.lines} lines)`;
              },
              label: (item) => {
                const d = DATA[item.dataIndex];
                if (item.datasetIndex === 0) {
                  return [
                    `  cmakefmt:      ${d.cmakefmt.toFixed(3)} ms`,
                    `  speedup:       ${d.speedup}×`,
                  ];
                }
                return `  cmake-format:  ${d.legacy.toFixed(3)} ms`;
              },
            },
          },
        },
      },
    });
  }

  function setScale(log: boolean) {
    logScale = log;
    btnLinear.classList.toggle("active",  !log);
    btnLog.classList.toggle("active",      log);
    buildChart();
  }

  btnLinear.addEventListener("click", () => setScale(false));
  btnLog.addEventListener(   "click", () => setScale(true));

  buildChart();

  // Re-render when the theme toggles
  const observer = new MutationObserver(() => buildChart());
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
</script>

<style>
  .chart-wrapper {
    position: relative;
    width: 100%;
    max-width: 860px;
    margin: 1.5rem auto;
    border: 1px solid var(--sl-color-hairline, hsl(240, 6%, 90%));
    border-radius: 0.75rem;
    padding: 1.5rem 1rem 1rem;
    background: color-mix(in srgb, var(--sl-color-accent-low, hsl(200, 98%, 95%)) 10%, transparent);
  }

  .chart-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .scale-label {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3, hsl(240, 4%, 46%));
  }

  .scale-toggle {
    display: flex;
    gap: 0.25rem;
  }

  .scale-btn {
    padding: 0.2rem 0.65rem;
    font-size: 0.75rem;
    cursor: pointer;
    border: 1px solid var(--sl-color-hairline, hsl(240, 6%, 90%));
    border-radius: 0.375rem;
    background: transparent;
    color: var(--sl-color-gray-3, hsl(240, 4%, 46%));
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .scale-btn:hover:not(.active) {
    background: var(--sl-color-gray-6, hsl(240, 6%, 90%));
    color: var(--sl-color-text, hsl(240, 6%, 10%));
  }

  .scale-btn.active {
    background: var(--sl-color-accent, hsl(200, 98%, 39%));
    border-color: var(--sl-color-accent, hsl(200, 98%, 39%));
    color: #fff;
  }
</style>

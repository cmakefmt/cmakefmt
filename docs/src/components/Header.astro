import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import { Icon } from '@astrojs/starlight/components';

import { siteNavLinks } from './siteNav';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const currentPath = Astro.url.pathname;
const { hasSidebar } = Astro.locals.starlightRoute;
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <div class="sl-flex print:hidden search-wrapper">
    {shouldRenderSearch && <Search />}
  </div>
  <div class="sl-flex md:sl-hidden print:hidden mobile-actions">
    <a href="https://github.com/cmakefmt/cmakefmt" class="icon-link" aria-label="GitHub" title="GitHub">
      <Icon name="github" size="1rem" color="var(--sl-color-text-accent)" />
    </a>
    <a
      href="https://crates.io/crates/cmakefmt-rust"
      class="icon-link rust-link"
      aria-label="crates.io"
      title="crates.io"
    >
      <Icon name="seti:rust" size="1rem" color="var(--sl-color-text-accent)" />
    </a>
    <button
      type="button"
      class="icon-link menu-toggle"
      data-mobile-menu-toggle
      aria-expanded="false"
      aria-controls={hasSidebar ? 'starlight__sidebar' : 'starlight__site-nav'}
      aria-label="Menu"
      title="Menu"
    >
      <Icon name="bars" size="1rem" class="menu-open-icon" color="var(--sl-color-text-accent)" />
      <Icon name="close" size="1rem" class="menu-close-icon" color="var(--sl-color-text-accent)" />
    </button>
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <nav class="header-nav" aria-label="Main">
      {siteNavLinks.map((link) => (
        <a href={link.href} class:list={['header-nav-link', { active: currentPath === link.href }]}>
          {link.label}
        </a>
      ))}
    </nav>
    <div class="sl-flex social-icons">
      <SocialIcons />
      <a
        href="https://crates.io/crates/cmakefmt-rust"
        class="icon-link rust-link"
        aria-label="crates.io"
        title="crates.io"
      >
        <Icon name="seti:rust" size="1rem" color="var(--sl-color-text-accent)" />
      </a>
    </div>
    <LanguageSelect />
  </div>
  <div class="sl-flex print:hidden theme-toggle-wrapper">
    <ThemeSelect />
  </div>
</div>

{
  !hasSidebar && (
    <div id="starlight__site-nav" class="mobile-site-drawer md:sl-hidden">
      <nav class="mobile-site-drawer-nav" aria-label="Main">
        {siteNavLinks.map((link) => (
          <a href={link.href} class:list={['mobile-site-drawer-link', { active: currentPath === link.href }]}>
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  )
}

<script>
  const mediaQuery = matchMedia('(min-width: 50rem)');

  const syncMobileMenuButtons = () => {
    const isOpen = document.body.hasAttribute('data-mobile-menu-expanded');
    document.querySelectorAll('[data-mobile-menu-toggle]').forEach((button) => {
      if (button instanceof HTMLButtonElement) {
        button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      }
    });
  };

  const setMobileMenuOpen = (open: boolean) => {
    document.body.toggleAttribute('data-mobile-menu-expanded', open);
    syncMobileMenuButtons();
  };

  syncMobileMenuButtons();

  document.querySelectorAll('[data-mobile-menu-toggle]').forEach((button) => {
    if (button instanceof HTMLButtonElement) {
      button.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        setMobileMenuOpen(!document.body.hasAttribute('data-mobile-menu-expanded'));
      });
    }
  });

  addEventListener('keyup', (event) => {
    if (event.key === 'Escape') setMobileMenuOpen(false);
  });

  mediaQuery.addEventListener('change', (event) => {
    if (event.matches) setMobileMenuOpen(false);
  });
</script>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
      min-width: 0;
    }

    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    .search-wrapper {
      min-width: 0;
      flex: 0 0 auto;
    }

    .right-group,
    .social-icons,
    .mobile-actions {
      gap: 1rem;
      align-items: center;
    }

    .social-icons::after {
      content: '';
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }

    .mobile-actions {
      gap: 0.125rem;
      margin-inline-start: 0.125rem;
    }

    .icon-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      border-radius: 999px;
      color: var(--sl-color-text-accent);
      text-decoration: none;
      transition:
        color 0.2s ease,
        background-color 0.2s ease;
    }

    .menu-toggle {
      border: 0;
      padding: 0;
      background: transparent;
      cursor: pointer;
    }

    .icon-link:hover {
      color: var(--sl-color-white);
      background-color: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    }

    .menu-close-icon {
      display: none;
    }

    .rust-link :global(svg) {
      font-size: 0.95rem;
    }

    .theme-toggle-wrapper {
      flex: 0 0 auto;
      align-items: center;
      margin-inline-start: 0.5rem;
    }

    .header-nav {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .header-nav-link {
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--sl-color-gray-3);
      text-decoration: none;
      padding: 0.25rem 0.625rem;
      border-radius: 0.375rem;
      position: relative;
      transition: color 0.2s ease;
    }

    .header-nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 0;
      height: 2px;
      background: var(--sl-color-accent);
      border-radius: 1px;
      transition:
        width 0.25s ease,
        left 0.25s ease;
    }

    .header-nav-link:hover {
      color: var(--sl-color-white);
    }

    .header-nav-link:hover::after,
    .header-nav-link.active::after {
      width: 60%;
      left: 20%;
    }

    .header-nav-link.active {
      color: var(--sl-color-text-accent);
    }

    .header-nav::after {
      content: '';
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
      margin-inline-start: 0.5rem;
    }

    .mobile-site-drawer {
      position: fixed;
      inset: var(--sl-nav-height) 0 auto;
      z-index: var(--sl-z-index-menu);
      max-height: calc(100vh - var(--sl-nav-height));
      overflow-y: auto;
      padding: 0.85rem var(--sl-nav-pad-x) 1rem;
      border-bottom: 1px solid var(--sl-color-hairline-shade);
      background: var(--sl-color-bg-nav);
      box-shadow: var(--sl-shadow-md);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(-0.4rem);
      transition:
        opacity 0.18s ease,
        transform 0.18s ease,
        visibility 0.18s ease;
    }

    .mobile-site-drawer-nav {
      display: grid;
      gap: 0.25rem;
    }

    .mobile-site-drawer-link {
      display: block;
      border-radius: 0.5rem;
      padding: 0.55rem 0.75rem;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--sl-color-gray-2);
      text-decoration: none;
    }

    .mobile-site-drawer-link:hover {
      color: var(--sl-color-white);
      background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    }

    .mobile-site-drawer-link.active {
      color: var(--sl-color-text-invert);
      background: var(--sl-color-text-accent);
    }

    @media (max-width: 49.999rem) {
      .header {
        gap: 0.25rem;
        justify-content: flex-end;
      }

      .title-wrapper {
        display: flex;
        flex: 1 1 auto;
        margin-inline-end: auto;
        min-width: 0;
      }

      .title-wrapper :global(.site-title) {
        min-width: 0;
      }

      .title-wrapper :global(.site-title span) {
        display: none;
      }

      .search-wrapper :global(button[data-open-modal]) {
        width: 2rem;
        min-width: 2rem;
        height: 2rem;
        padding: 0;
        justify-content: center;
        border: none;
        border-radius: 999px;
        background: transparent;
        color: var(--sl-color-text-accent);
      }

      .search-wrapper :global(button[data-open-modal] > span),
      .search-wrapper :global(button[data-open-modal] > kbd) {
        display: none !important;
      }

      .search-wrapper :global(button[data-open-modal]:hover) {
        color: var(--sl-color-white);
        background-color: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
      }

      .search-wrapper,
      .mobile-actions,
      .theme-toggle-wrapper {
        flex: 0 0 auto;
      }

      .search-wrapper {
        margin-inline-start: 0.125rem;
      }

      .mobile-actions {
        margin-inline-start: 0;
      }

      .theme-toggle-wrapper {
        margin-inline-start: 0.125rem;
      }

      :global(body[data-mobile-menu-expanded]) .menu-open-icon {
        display: none;
      }

      :global(body[data-mobile-menu-expanded]) .menu-close-icon {
        display: inline-flex;
      }

      :global(body[data-mobile-menu-expanded]) .mobile-site-drawer {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0);
      }
    }

    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }

      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }

      .header {
        --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
        --__main-column-fr: calc(
          (
              100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
                (2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
                var(--sl-content-width)
            ) / 2
        );
        display: grid;
        grid-template-columns:
          minmax(
            calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))),
            auto
          )
          1fr
          auto
          auto;
        align-content: center;
      }
    }
  }
</style>

<style is:global>
  @layer starlight.core {
    @media (max-width: 49.999rem) {
      body[data-mobile-menu-expanded] {
        overflow: hidden;
      }

      body[data-mobile-menu-expanded] #starlight__sidebar {
        visibility: visible;
      }
    }
  }

</style>

// DaisyUI-style toggle with icons inside, wired into Starlight's light/dark theme state.
---

<starlight-theme-select>
  <label class="toggle toggle-sm theme-toggle" title="Toggle theme">
    <input
      type="checkbox"
      class="theme-controller theme-toggle-input"
      value="dark"
      aria-label="Toggle theme"
    />
    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
      <g
        stroke-linejoin="round"
        stroke-linecap="round"
        stroke-width="2"
        fill="none"
        stroke="currentColor"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2"></path>
        <path d="M12 20v2"></path>
        <path d="m4.93 4.93 1.41 1.41"></path>
        <path d="m17.66 17.66 1.41 1.41"></path>
        <path d="M2 12h2"></path>
        <path d="M20 12h2"></path>
        <path d="m6.34 17.66-1.41 1.41"></path>
        <path d="m19.07 4.93-1.41 1.41"></path>
      </g>
    </svg>
    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
      <g
        stroke-linejoin="round"
        stroke-linecap="round"
        stroke-width="2"
        fill="none"
        stroke="currentColor"
      >
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
      </g>
    </svg>
  </label>
  <select aria-hidden="true" style="display:none">
    <option value="dark">Dark</option>
    <option value="light">Light</option>
    <option value="auto" selected>Auto</option>
  </select>
</starlight-theme-select>

<script is:inline>
  StarlightThemeProvider.updatePickers();
</script>

<script>
  type Theme = 'auto' | 'dark' | 'light';

  const storageKey = 'starlight-theme';

  const parseTheme = (theme: unknown): Theme =>
    theme === 'auto' || theme === 'dark' || theme === 'light' ? theme : 'auto';

  const loadTheme = (): Theme =>
    parseTheme(typeof localStorage !== 'undefined' && localStorage.getItem(storageKey));

  function storeTheme(theme: Theme): void {
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem(storageKey, theme === 'light' || theme === 'dark' ? theme : '');
    }
  }

  const getPreferredColorScheme = (): 'light' | 'dark' =>
    matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';

  function syncThemeToggles(theme: Theme): void {
    const resolved = theme === 'auto' ? getPreferredColorScheme() : theme;

    document.querySelectorAll('starlight-theme-select').forEach((picker) => {
      const checkbox = picker.querySelector('.theme-toggle-input');
      if (checkbox instanceof HTMLInputElement) {
        checkbox.checked = resolved === 'dark';
      }

      const select = picker.querySelector('select');
      if (select instanceof HTMLSelectElement) {
        select.value = theme;
      }
    });
  }

  function onThemeChange(theme: Theme): void {
    const resolved = theme === 'auto' ? getPreferredColorScheme() : theme;

    StarlightThemeProvider.updatePickers(theme);
    document.documentElement.dataset.theme = resolved;
    storeTheme(theme);
    syncThemeToggles(theme);
  }

  matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
    if (loadTheme() === 'auto') onThemeChange('auto');
  });

  class StarlightThemeSelect extends HTMLElement {
    checkbox = this.querySelector('.theme-toggle-input');
    select = this.querySelector('select');

    constructor() {
      super();

      onThemeChange(loadTheme());

      this.checkbox?.addEventListener('change', () => {
        onThemeChange(this.checkbox instanceof HTMLInputElement && this.checkbox.checked ? 'dark' : 'light');
      });

      this.select?.addEventListener('change', (e) => {
        if (e.currentTarget instanceof HTMLSelectElement) {
          onThemeChange(parseTheme(e.currentTarget.value));
        }
      });
    }
  }

  customElements.define('starlight-theme-select', StarlightThemeSelect);
</script>

<style>
  .theme-toggle {
    color: var(--sl-color-text-accent);
    --input-color: color-mix(in srgb, var(--sl-color-text-accent) 55%, var(--sl-color-gray-4));
    background-color: color-mix(in srgb, var(--sl-color-gray-6) 92%, var(--sl-color-black));
    border-color: color-mix(in srgb, var(--sl-color-accent) 28%, var(--sl-color-gray-5));
    box-shadow: none;
  }

  .theme-toggle svg {
    width: 0.8rem;
    height: 0.8rem;
  }

  .theme-toggle:has(> input:checked) {
    --input-color: var(--sl-color-text-accent);
    background-color: color-mix(in srgb, var(--sl-color-accent) 12%, var(--sl-color-black));
  }

  .theme-toggle-input {
    cursor: pointer;
  }

  .theme-toggle:hover {
    border-color: var(--sl-color-text-accent);
  }

  .theme-toggle:has(> input:focus-visible),
  .theme-toggle-input:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--sl-color-accent) 45%, transparent);
    outline-offset: 2px;
  }
</style>
